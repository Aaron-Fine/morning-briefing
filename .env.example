# Morning Digest — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# Required: Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Required: Finnhub API key — free tier at https://finnhub.io
# Used for market quotes and economic calendar
FINNHUB_API_KEY=

# Required: Gmail SMTP credentials
# Use an App Password, NOT your regular password:
# https://myaccount.google.com/apppasswords
SMTP_USER=you@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional: Alpha Vantage API key for market data fallback
# ALPHA_VANTAGE_KEY=
